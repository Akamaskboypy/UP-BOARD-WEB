rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Data Model Validation
    // ===============================================================
    function isValidProgress(data) {
      return data.keys().hasAll(['state']) &&
             data.state is map;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /artifacts/upboard-checklist/users/{userId}/progress/upboard_5subj_tasks {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidProgress(request.resource.data);
      allow delete: if isOwner(userId);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
